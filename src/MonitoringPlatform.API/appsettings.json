{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=your_database;Username=postgres;Password=your_password"
  },
  "MonitoringEngine": {
    "GlobalIntervalSeconds": 10,
    "HttpTimeoutSeconds": 5,
    "MaxRetries": 2,
    "MaxConcurrentChecks": 4
  },
  "Jwt": {
    "Secret": "change-this-dev-secret-to-a-long-random-value-1234567890",
    "Issuer": "CloudAlertHub",
    "Audience": "CloudAlertHub.Frontend",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 14
  },
  "MicrosoftGraph": {
    "Enabled": false,
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "AuthorityBaseUrl": "https://login.microsoftonline.com",
    "GraphBaseUrl": "https://graph.microsoft.com/v1.0"
  },
  "CloudStatus": {
    "Enabled": true,
    "IntervalSeconds": 300,
    "HttpTimeoutSeconds": 20,
    "Providers": [
      {
        "Name": "Cloudflare",
        "Slug": "cloudflare",
        "LogoUrl": "https://cdn.simpleicons.org/cloudflare/F38020",
        "SourceType": "StatuspageApi",
        "SourceUrl": "https://www.cloudflarestatus.com/api/v2/incidents.json",
        "StatusPageUrl": "https://www.cloudflarestatus.com",
        "IsEnabled": true
      },
      {
        "Name": "GitHub",
        "Slug": "github",
        "LogoUrl": "https://cdn.simpleicons.org/github/181717",
        "SourceType": "StatuspageApi",
        "SourceUrl": "https://www.githubstatus.com/api/v2/incidents.json",
        "StatusPageUrl": "https://www.githubstatus.com",
        "IsEnabled": true
      },
      {
        "Name": "OpenAI",
        "Slug": "openai",
        "LogoUrl": "https://cdn.simpleicons.org/openai/412991",
        "SourceType": "JsonApi",
        "SourceUrl": "https://status.openai.com/api/v2/incidents.json",
        "StatusPageUrl": "https://status.openai.com",
        "IsEnabled": true
      },
      {
        "Name": "AWS",
        "Slug": "aws",
        "LogoUrl": "https://cdn.simpleicons.org/amazonaws/FF9900",
        "SourceType": "Rss",
        "SourceUrl": "https://status.aws.amazon.com/rss/all.rss",
        "StatusPageUrl": "https://status.aws.amazon.com",
        "IsEnabled": true
      },
      {
        "Name": "Microsoft 365",
        "Slug": "microsoft-365",
        "LogoUrl": "https://res-1.cdn.office.net/files/fabric-cdn-prod_20230815.002/assets/brand-icons/product/svg/m365_24x1.svg",
        "SourceType": "MicrosoftGraphServiceHealth",
        "SourceUrl": "https://graph.microsoft.com/v1.0/admin/serviceAnnouncement/issues",
        "StatusPageUrl": "https://admin.microsoft.com/Adminportal/Home#/servicehealth",
        "Metadata": {
          "ServiceNames": [
            "Exchange Online",
            "Microsoft Teams",
            "SharePoint Online",
            "OneDrive for Business",
            "Microsoft 365 suite",
            "Microsoft 365 admin center",
            "Viva Engage",
            "Microsoft Defender for Office 365"
          ],
          "ServiceKeywords": [
            "Exchange",
            "Teams",
            "SharePoint",
            "OneDrive",
            "Microsoft 365",
            "Outlook",
            "Office on the web",
            "Defender for Office 365",
            "Viva"
          ]
        },
        "IsEnabled": true
      },
      {
        "Name": "Power Platform",
        "Slug": "power-platform",
        "LogoUrl": "https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg",
        "SourceType": "MicrosoftGraphServiceHealth",
        "SourceUrl": "https://graph.microsoft.com/v1.0/admin/serviceAnnouncement/issues",
        "StatusPageUrl": "https://admin.powerplatform.microsoft.com/health",
        "Metadata": {
          "ServiceKeywords": [
            "Power Platform",
            "Power Apps",
            "Power Automate",
            "Power Pages",
            "Copilot Studio",
            "Dataverse",
            "Dynamics 365",
            "Customer Service",
            "Field Service",
            "Sales"
          ]
        },
        "IsEnabled": true
      }
    ]
  },
  "Email": {
    "Enabled": true,
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SenderEmail": "",
    "SenderName": "Cloud Alert Hub",
    "UseSsl": true
  }
}
